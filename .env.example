# PostgreSQL connection template.
# Copy this file to ".env" and replace the placeholders with local values.
# Do not commit real credentials.

DB_USER=postgres
DB_PASSWORD=change_me
DB_HOST=localhost
DB_PORT=5432
DB_NAME=infonavit

# Optional managed PostgreSQL connection string for Supabase, Cloud SQL, etc.
# If set, DATABASE_URL takes precedence over DB_USER/DB_PASSWORD/DB_HOST/DB_PORT/DB_NAME.
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/database

# API key for protected FastAPI endpoints. Use a local-only value here.
# In Cloud Run, configure this through Secret Manager or a secure variable.
INFONAVIT_API_KEY=change_me_local_only

# Optional inflation service used by the extended report.
# If not configured or unavailable, the report falls back to nominal metrics.
INFLACION_COPILOT_URL=https://inflacion-copilot-api-490229283844.us-central1.run.app
INFLACION_COPILOT_TIMEOUT_SECONDS=20

# Optional AI-assisted executive interpretation.
# Leave OPENAI_API_KEY empty to keep AI disabled.
# Never commit real API keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
